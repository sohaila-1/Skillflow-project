# App
NODE_ENV=development
PORT=3000
API_VERSION=v1

# Database
DATABASE_URL=postgresql://skillflow:skillflow@postgres:5432/skillflow

# Keycloak / IAM
KEYCLOAK_URL=http://keycloak:8080
KEYCLOAK_REALM=skillflow
KEYCLOAK_CLIENT_ID=skillflow-backend
KEYCLOAK_CLIENT_SECRET=your-client-secret

# GCP Pub/Sub
PUBSUB_PROJECT_ID=skillflow-local
PUBSUB_EMULATOR_HOST=pubsub-emulator:8085
PUBSUB_TOPIC_REQUESTS=worker-requests
PUBSUB_TOPIC_RESPONSES=worker-responses
PUBSUB_SUB_RESPONSES=backend-responses-sub

# Correlation
LOG_LEVEL=debug
