{
  "name": "@skillflow/worker",
  "version": "1.0.0",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "start:dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "lint": "eslint 'src/**/*.ts'",
    "test": "jest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@google-cloud/pubsub": "^4.5.0",
    "neverthrow": "^8.0.0",
    "pino": "^9.3.2",
    "uuid": "^10.0.0",
    "pdfkit": "^0.15.0",
    "nodemailer": "^6.9.14"
  },
  "jest": {
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": { "^.+\\.ts$": "ts-jest" },
    "testEnvironment": "node",
    "moduleFileExtensions": ["js", "json", "ts"]
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.12",
    "@types/pdfkit": "^0.13.5",
    "@types/nodemailer": "^6.4.15",
    "@typescript-eslint/eslint-plugin": "^7.17.0",
    "@typescript-eslint/parser": "^7.17.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.3",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.4"
  }
}
